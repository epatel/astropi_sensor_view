[Unit]
Description=AstroPi Sensor View Dashboard
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/projects/sensor-view
ExecStart=/home/pi/venv/bin/python3 /home/pi/projects/sensor-view/server.py
Restart=on-failure
RestartSec=10
StartLimitIntervalSec=60
StartLimitBurst=5

[Install]
WantedBy=multi-user.target
